[flake8]
# Line-length raised to 120; remaining ignores are cosmetic issues and
# star-import artifacts present in the pre-built starter components,
# which the project instructions require to be left unchanged.
max-line-length = 120
exclude = .git,__pycache__,build,dist,.venv,venv,env,src
extend-ignore = E111,E114,E225,E231,E251,E302,E303,E401,E501,E731,F401,F403,F405,F901,W291,W292,W293,W391
